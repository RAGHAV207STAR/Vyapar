{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores shop profile and contact details for billing",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "firebaseUid": { "type": "string" },
        "businessId": { "type": "string" },
        "email": { "type": "string" },
        "shopName": { "type": "string" },
        "ownerName": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "logo": { "type": "string" },
        "category": { "type": "string" },
        "gstNumber": { "type": "string" },
        "invoicePrefix": { "type": "string" },
        "barcodeScannerEnabled": { "type": "boolean" },
        "businessDescription": { "type": "string" },
        "socialLinks": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "role": { "type": "string" },
        "notificationSettings": {
          "type": "object",
          "properties": {
            "lowStockAlerts": { "type": "boolean" },
            "duePaymentReminders": { "type": "boolean" },
            "dailyBusinessSummary": { "type": "boolean" },
            "weeklyBusinessReport": { "type": "boolean" },
            "monthlyPerformanceReport": { "type": "boolean" },
            "businessInactivityReminders": { "type": "boolean" },
            "inventoryReviewReminders": { "type": "boolean" },
            "securityAlerts": { "type": "boolean" },
            "exportCompletionNotifications": { "type": "boolean" }
          }
        },
        "registeredTokens": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["uid", "firebaseUid", "businessId", "email", "shopName", "ownerName", "phone", "address"]
    },
    "Notification": {
      "title": "Notification",
      "description": "Stores push and system notifications for cross-device syncing",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "body": { "type": "string" },
        "type": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "body", "type", "read", "createdAt"]
    },
    "Bill": {
      "title": "Bill",
      "description": "Stores digital invoices generated by shop owners",
      "type": "object",
      "properties": {
        "billId": { "type": "string" },
        "userId": { "type": "string" },
        "invoiceNumber": { "type": "string" },
        "invoiceDate": { "type": "string" },
        "customerDetails": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "phone": { "type": "string" },
            "address": { "type": "string" }
          },
          "required": ["name"]
        },
        "products": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" },
              "total": { "type": "number" }
            },
            "required": ["name", "quantity", "price", "total"]
          }
        },
        "totalAmount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["billId", "userId", "customerDetails", "products", "totalAmount", "createdAt"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Stores customer details managed by the shop owner",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "gstNumber": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "name", "phone", "address", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles and shop settings"
    },
    "bills/{billId}": {
      "schema": "Bill",
      "description": "Bills generated by users"
    },
    "notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notification messages"
    },
    "customers/{customerId}": {
      "schema": "Customer",
      "description": "Customer profiles managed by users"
    }
  }
}
